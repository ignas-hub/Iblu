# =====================================================================
# iblu-keeper — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =====================================================================

# ---------------------------------------------------------------------
# MCP SERVER
# ---------------------------------------------------------------------
# Host/port the FastMCP HTTP server binds to (behind Caddy/nginx).
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Bearer token Claude must send to use the MCP server.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=change-me-to-a-long-random-string

# DRY_RUN=true  -> no Google calls; Chat/Gmail/Calendar return mock data.
# Leave true until the Google service-account access has been validated.
DRY_RUN=true

# ---------------------------------------------------------------------
# GOOGLE SERVICE ACCOUNT (Gmail / Calendar / Chat)
# ---------------------------------------------------------------------
# Provide the service-account key EITHER as a file path OR base64.
# Path form (recommended on the server):
GOOGLE_SERVICE_ACCOUNT_FILE=/etc/iblu-keeper/service-account.json
# OR base64 form (handy for env-only deploys). If set, takes precedence:
# GOOGLE_SERVICE_ACCOUNT_B64=

# The single Workspace user the service account impersonates
# (domain-wide delegation scoped to just this address).
GOOGLE_DELEGATED_USER=ignas@blanklabel.team

# ---------------------------------------------------------------------
# STREAMLIT DASHBOARD — Google OAuth login (restrict to one account)
# ---------------------------------------------------------------------
DASHBOARD_OAUTH_CLIENT_ID=
DASHBOARD_OAUTH_CLIENT_SECRET=
# Must exactly match an Authorized redirect URI in Google Cloud console.
DASHBOARD_OAUTH_REDIRECT_URI=http://localhost:8501/
# Only this Google account may log into the dashboard.
DASHBOARD_ALLOWED_EMAIL=ignas@blanklabel.team
# Random string used to sign the dashboard session cookie.
DASHBOARD_COOKIE_SECRET=change-me-to-another-long-random-string
# Where the dashboard reaches the MCP server (for health/status checks).
DASHBOARD_MCP_BASE_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------
# PHASE 2 — POSTGRES (declared now, unused in Phase 1)
# ---------------------------------------------------------------------
# DATABASE_URL=postgresql+psycopg://iblu:password@localhost:5432/iblu_keeper
