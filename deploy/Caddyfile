# iblu-keeper — Caddy reverse proxy (recommended; automatic HTTPS).
#
# Place at /etc/caddy/Caddyfile (or include it). Caddy obtains Let's Encrypt
# certs automatically. If Cloudflare is in front, set the Cloudflare SSL/TLS
# mode to "Full (strict)" so the edge trusts Caddy's real cert.
#
# Subdomains of iblugames.com.

# MCP server — what Claude's custom connector points at.
mcp.iblugames.com {
    encode gzip
    reverse_proxy 127.0.0.1:8000
}

# Dashboard / command center.
keeper.iblugames.com {
    encode gzip
    reverse_proxy 127.0.0.1:8501
}
