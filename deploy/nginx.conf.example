# iblu-keeper — nginx reverse proxy (alternative to Caddy).
#
# Use with certbot for Let's Encrypt:
#   sudo certbot --nginx -d mcp.iblugames.com -d keeper.iblugames.com
# If Cloudflare is in front, set SSL/TLS mode to "Full (strict)".
#
# Streamlit and MCP streamable-HTTP both need WebSocket upgrade + long timeouts.

# ---- MCP server ----
server {
    listen 80;
    server_name mcp.iblugames.com;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_buffering off;
    }
}

# ---- Dashboard ----
server {
    listen 80;
    server_name keeper.iblugames.com;

    location / {
        proxy_pass http://127.0.0.1:8501;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
    }
}
